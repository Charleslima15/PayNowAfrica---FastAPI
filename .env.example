# App
APP_NAME=PayNow Africa Auth Service
DEBUG=false
SECRET_KEY=your-256-bit-secret-key-here
ALGORITHM=HS256

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/paynow_auth
REDIS_URL=redis://localhost:6379/0

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# SendGrid
SENDGRID_API_KEY=your-sendgrid-key
FROM_EMAIL=noreply@paynow-africa.com

# Africa's Talking (SMS)
AT_USERNAME=your-username
AT_API_KEY=your-api-key

# Smile Identity (KYC)
SMILE_PARTNER_ID=your-partner-id
SMILE_API_KEY=your-api-key
SMILE_ENVIRONMENT=sandbox

# Encryption (for KYC data at rest)
ENCRYPTION_KEY=your-32-byte-encryption-key